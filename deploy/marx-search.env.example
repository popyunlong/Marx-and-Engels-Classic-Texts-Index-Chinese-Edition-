APP_MODE=server
BIND_HOST=127.0.0.1
PORT=8000
PUBLIC_BASE_URL=https://marx-search.example.com
ENABLE_BROWSER_AUTOSTART=0
ENABLE_IDLE_SHUTDOWN=0
ENABLE_REMOTE_QUIT=0
SECURITY_CONTACT=mailto:security@marx-search.example.com
MAX_RELEASE_UPLOAD_MB=200
# Synthetic/uptime monitors: exempt them so their periodic hits do NOT inflate the
# admin overview (reader views / online / anomalies). Comma-separated lists.
# A monitor that logs in as test accounts is best exempted by ACCOUNT IDENTITY
# (unspoofable): list its member/non-member emails (or numeric user ids). For its
# guest leg, use a distinctive User-Agent (case-insensitive substring; treat as a
# SECRET since UA is forgeable) or a fixed egress IP. The hot-editable setting
# `monitoring_exemptions` ({"emails":[],"user_ids":[],"user_agents":[],"ips":[]})
# is merged on top.
MONITORING_EMAILS=
MONITORING_USER_IDS=
MONITORING_USER_AGENTS=
MONITORING_IPS=
# AI scraper bots (GPTBot, ClaudeBot, CCBot, Bytespider, Amazonbot, Google-Extended,
# PerplexityBot, ...) are hard-blocked with 403 on reader/content endpoints by a built-in
# list. Add extra UA substrings here (comma-separated, case-insensitive) to extend it; the
# hot-editable setting `blocked_bot_user_agents` (a JSON list) also merges on top.
# Emergency kill switch: set DISABLE_BOT_UA_BLOCK=1 to disable all UA blocking.
BLOCKED_BOT_USER_AGENTS=
DISABLE_BOT_UA_BLOCK=
# Per-real-IP rate limits on reader content endpoints (NAT-tolerant; only catch single-IP
# bulk scraping). Format "limit,window_seconds". Leave blank to use built-in defaults
# (/viewer 200/60s, /page-image 1500/60s per IP). Admins and exempt monitors are never limited.
READER_VIEW_IP_RATE=
READER_PAGEIMG_IP_RATE=
# Conservative auto-ban of egregious real-IP scrapers (public IPs only; never bans logged-in
# members / internal / monitor IPs). Fires only when an IP crosses BOTH a high daily count AND
# a high per-minute peak. Set DISABLE_READER_AUTO_BAN=1 to turn it off; the hot-editable setting
# `reader_auto_ban` ({"enabled":true,"daily_min":2000,"minute_min":90}) also overrides.
DISABLE_READER_AUTO_BAN=
READER_AUTO_BAN_DAILY_MIN=
READER_AUTO_BAN_MINUTE_MIN=
# Leave blank in the first cloud deployment if you want AI disabled.
ZAI_API_KEY=
# Optional: split the answer model from the web search service.
# Example: APP_AI_PROVIDER=deepseek with APP_AI_SEARCH_PROVIDER=zai.
APP_AI_PROVIDER=
APP_AI_MODEL=
APP_AI_BASE_URL=
APP_AI_API_KEY=
APP_AI_SEARCH_PROVIDER=
APP_AI_SEARCH_BASE_URL=
APP_AI_SEARCH_API_KEY=

# ZPay / 易支付 page pay.
ZPAY_PID=
ZPAY_KEY=
ZPAY_SUBMIT_URL=https://zpayz.cn/submit.php
ZPAY_MAPI_URL=https://zpayz.cn/mapi.php
ZPAY_API_URL=https://zpayz.cn/api.php
ZPAY_TYPE=alipay
ZPAY_CHANNEL_ID=
ZPAY_SIGN_TYPE=MD5
ZPAY_SUBJECT_PREFIX=马恩文献检索会员
ZPAY_DEVICE=pc
# Leave blank to derive from PUBLIC_BASE_URL:
# ZPAY_NOTIFY_URL=https://marx-search.example.com/payments/zpay/notify
# ZPAY_RETURN_URL=https://marx-search.example.com/payments/zpay/return
ZPAY_NOTIFY_URL=
ZPAY_RETURN_URL=

# Cloudflare Turnstile. Leave keys blank to rely on rate limiting until configured.
TURNSTILE_ENABLED=1
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# SMTP is used by registration email codes, password reset, and the 09:00 Beijing daily journal digest.
JOURNAL_ALERT_BASE_URL=https://marx-search.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=马著作检索
SMTP_USE_TLS=1

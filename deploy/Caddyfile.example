marx-search.example.com {
    encode gzip zstd

    respond /control* 404

    reverse_proxy 127.0.0.1:8000

    header {
        -Server
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self' https://zpayz.cn https://*.zpayz.cn https://z-pay.cn https://*.z-pay.cn; frame-ancestors 'self'"
        Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"
    }

    log
}

# 默认：文本统一 LF，自动识别二进制
* text=auto eol=lf

# 显式文本类型（统一 LF）
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Windows 脚本保持 CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf

# 第三方 vendor 整体当二进制：不做行级 diff，避免 diff 膨胀与 CRLF 噪声
static/vendor/** -text -diff

# 二进制资源
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.icns binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.wasm binary
*.sqlite binary
*.pdf binary

# 既有规则（保留语义）
data/corpus.sqlite filter=lfs diff=lfs merge=lfs -text
deploy/bootstrap_ubuntu.sh text eol=lf
